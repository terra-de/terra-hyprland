{
  "version": 1,

  "monitors": [
    { "output": "eDP-1", "mode": "preferred", "position": "auto", "scale": 1.5 },
    { "output": "HDMI-A-1", "mode": "1920x1080@144", "position": "auto-right", "scale": 1.0 }
  ],

  "input": {
    "touchpad": {
      "disable_while_typing": true,
      "natural_scroll": true,
      "scroll_factor": 0.7
    }
  },

  "env": {
    "GTK_ICON_THEME": "material-actions"
  },

  "window_rules": {
    "additional": []
  },

  "workspace_rules": []
}
